{
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/.idea": true,
    "**/.replit": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/.wrangler": true,
    "playwright-report": true,
  },
  "typescript.experimental.useTsgo": true,
  "json.schemaDownload.enable": true,
  "eslint.enable": false,
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "explicit",
    "source.fixAll.biome": "explicit"
  }
}
