{
  "name": "@workspace/pdf-collab",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "tsc -b && vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:server": "vitest run --config vitest.config.server.ts",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:install": "playwright install --with-deps chromium",
    "storybook": "storybook dev -p 6006",
    "deploy": "bun run build && wrangler deploy --minify",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply party-pdf-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply party-pdf-db --remote",
    "db:studio": "drizzle-kit studio",
    "build-storybook": "storybook build",
    "biome:check": "biome check --write --no-errors-on-unmatched ./src",
    "biome:lint": "biome lint --no-errors-on-unmatched ./src",
    "biome:format": "biome format --write --no-errors-on-unmatched ./src",
    "biome:ci": "biome ci ./src"
  },
